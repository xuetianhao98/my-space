---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BlogDirectory from "../components/BlogDirectory.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { getPublishedPosts } from "../lib/blog";

type Props = CollectionEntry<"blog">["data"] & {
  currentPostId: string;
};

const { title, description, pubDate, updatedDate, currentPostId } = Astro.props;
const posts = await getPublishedPosts();
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        display: grid;
        grid-template-columns: minmax(14rem, 18rem) minmax(0, 720px);
        justify-content: center;
        gap: clamp(2rem, 5vw, 5rem);
        width: auto;
        max-width: 1280px;
        margin: auto;
        padding: 3rem 2rem 5rem;
      }
      .prose {
        min-width: 0;
        color: rgb(var(--gray-dark));
      }
      .title {
        margin-bottom: 2.5rem;
        padding: 0 0 1.25rem;
        text-align: left;
        line-height: 1;
      }
      .title h1 {
        margin: 0.35rem 0 0;
        font-size: clamp(2.2rem, 6vw, 3.05rem);
        line-height: 1.08;
      }
      .date {
        margin-bottom: 0.5rem;
        color: rgb(var(--gray));
        font-size: 0.9rem;
      }
      .last-updated-on {
        display: inline;
        margin-left: 0.6rem;
        font-style: italic;
      }
      .title hr {
        margin-top: 1.5rem;
      }

      @media (max-width: 900px) {
        main {
          grid-template-columns: minmax(0, 720px);
          gap: 2rem;
          padding: 2rem 1rem 4rem;
        }
      }

      @media (max-width: 520px) {
        main {
          padding-inline: 1rem;
        }

        .last-updated-on {
          display: block;
          margin: 0.2rem 0 0;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <BlogDirectory posts={posts} currentPostId={currentPostId} />
      <article>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            <h1>{title}</h1>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
